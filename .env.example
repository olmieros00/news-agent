# Copy to .env and fill in. Do not commit .env.

# Guardian Open Platform (required for Guardian connector)
GUARDIAN_API_KEY=

# NewsAPI (optional, Tier 2 discovery)
NEWSAPI_KEY=

# Telegram (for delivery layer)
TELEGRAM_BOT_TOKEN=

# Optional: OpenAI for neutral headline/body/bias generation
# OPENAI_API_KEY=

# Storage
DB_PATH=

# Briefing: max headlines (default 10). Only stories with 3+ articles are shown.
# TOP_N_STORIES=10

# How far back to read raw items for the briefing (hours). Default 12.
# PIPELINE_HOURS_LOOKBACK=12

# DB pruning: keep raw items for this many days (older rows deleted on each run). Default 3.
# DB_KEEP_DAYS=3

# Pipeline speed: max items for translate+cluster (0 = no cap). Default 3000.
# PIPELINE_MAX_ITEMS=3000
